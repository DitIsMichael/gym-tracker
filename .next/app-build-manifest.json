    ],
    "/onboarding/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/onboarding/page.js"
    ],
    "/(app)/sessies/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/sessies/page.js"
    ],
    "/(app)/progressie/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/progressie/page.js"
    ],
    "/(app)/profiel/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/profiel/page.js"
    ],
    "/(app)/sessies/[id]/page": [
